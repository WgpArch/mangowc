{
    "custom/arch": {
        "format": "≤░μΘ",
        "on-click": "rofi -show drun -theme purple.rasi",
        "tooltip": true,
        "tooltip-format": "btw ΏθαΟ"
    },
    
    "ext/workspaces": {
    "format": "{icon}",
    "ignore-hidden": false,
    "on-click": "activate",
    "sort-by-id": true
  },
  
  "dwl/tags": {
    "num-tags": 11
  },
  "dwl/window#layout": {
    "format": "[{layout}]"
  },
  "dwl/window": {
    "format": "{}",
	"max-length": 25,
	"separate-outputs": true,
	"offscreen-css": true,
	"offscreen-css-text": "(inactive)",
  },

    "custom/mako": {
	"tooltip": true,
	"tooltip-format": "Left Click: Show Expired Notifications",
	"format": "ΎΓλ",
	"return-type": "json",
	"on-click": "makoctl restore",
	"escape": true,
},


    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-bluetooth": "{icon} {volume}% ΎΛΦ {format_source}",
        "format-bluetooth-muted": "Ύγσ {icon}ΎΛΦ {format_source}",
        "format-muted": "Ύγσ {format_source}",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΨΡ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "on-click": "pavucontrol"
    },
    
    "pulseaudio#microphone": {
	"format": "{format_source}",
	"format-source": "ΎΕ░ {volume}%",
	"format-source-muted": "ΎΕ▒",
	"on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
	"on-click-right": "pavucontrol -t 4",
	"on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%-",
	"on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 5%+",
	"tooltip-format": "{source_desc} | {source_volume}%",
	"scroll-step": 5,
},

    "network": {
	"format": "{ifname}",
	"format-wifi": "{icon}",
	"format-ethernet": "≤░Να",
	"format-disconnected": "≤░Νβ",
	"tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBits} ΎΕ║ {bandwidthDownBits}",
	"format-linked": "≤░ΙΒ {ifname} (No IP)",
	"tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
	"tooltip-format-ethernet": "{ifname} ≤░Να",
	"tooltip-format-disconnected": "≤░Νβ Disconnected",
	"max-length": 30,
	"format-icons": [
		"≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"
	],
        "on-click": "nm-connection-editor"
	
},
	"network#speed": {
	"interval": 1,
	"format": "{ifname}",
	"format-wifi": "{icon} ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
	"format-ethernet": "≤░Να ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
	"format-disconnected": "≤░Νβ",
	"tooltip-format": "{ipaddr}",
	"format-linked": "≤░ΙΒ {ifname} (No IP)",
	"tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
	"tooltip-format-ethernet": "{ifname} ≤░Να",
	"tooltip-format-disconnected": "≤░Νβ Disconnected",
	"min-length": 24,
	"max-length": 24,
	"format-icons": [
		"≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"
	]
},
    "cpu": {
        "format": "ΎΜδ  {usage}%",
        "tooltip": true,
        "on-click": "xfce4-terminal btop &"
    },
    "memory": {
        "format": "ΎΔΚ  {}%",
		"tooltip": true,
		"on-click": "xfce4-terminal btop &"
    },
    "temperature": {
        "interval": 10,
        "hwmon-path": "/sys/devices/platform/coretemp.0/hwmon/hwmon5/temp1_input",
        "critical-threshold": 100,
        "format-critical": "ΎΜΘ {temperatureC}",
        "format": "ΎΜΚ {temperatureC}┬░C"
    },

    "battery": {
        "states": {
			"good": 95,
            "warning": 30,
            "critical": 20
        },
        "on-click-middle": "xfce-terminal acpi -i",
        "format": "{icon}  {capacity}%",
        "format-full": "{icon}  {capacity}%",
        "format-charging": "ΎΩπ  {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{time}  {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]        
    },
   
    
    "clock": {
    "interval": 1,
    "format": "{:%b %d %H:%M:%S %p}",
    "tooltip-format": "<span color='#FFFFFF'><tt>{calendar}</tt></span>",
    "calendar": {
      "mode-mon-col": 4,
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#BE95FF'><b>{}</b></span>",
        "weeks": "<span color='#525252'><b>{}</b></span>",
        "weekdays": "<span color='#78A9FF'><b>{}</b></span>",
        "today": "<span color='#BE95FF' background='#161616'><b>{}</b></span>"
      }
    },
     "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "tooltip": true  
  },

     "custom/weather": {
        "format": "{}",
        "tooltip": true,
        "return-type": "json",
        "exec": "~/.config/mango/waybar1/weather/waybar/scripts/weather/get_weather.rb",
        "on-click": "~/.config/mango/waybar1/weather/waybar/scripts/weather/get_weather.rb --next",
        "interval": 900
},
  
  
    "power-profiles-daemon": {
		"format": "{icon}",
		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
		"tooltip": true,
		"format-icons": {
		"default": "ΎΔπ",
		"performance": "ΎΔπ",
		"balanced": "ΎΚΟ",
		"power-saver": "ΎΒυ"
	}
	},
    "custom/power": {
        "tooltip": false,
        "on-click": "bash ~/.config/rofi/powermenu.sh",
        "on-click-right": "killall rofi",
        "format": "έΠ╗ ",
    },
    "tray": {
	"icon-size": 20,
	"spacing": 4,
	},
	"bluetooth": {
	"format": "ΎΛΥ",
	"format-disabled": "≤░Γ│",
	"format-connected": "≤░Γ▒ {num_connections}",
	"tooltip-format": "ΎΛΥ {device_alias}",
	"tooltip-format-connected": "{device_enumerate}",
	"tooltip-format-enumerate-connected": "ΎΛΥ {device_alias} ≤░ΓΕ{device_battery_percentage}%",
	"tooltip": true,
	"on-click": "blueberry",
},
"backlight": {
	"interval": 2,
	"align": 0,
	"rotate": 0,
	"format": "{icon} {percent}%",
	"format-icons": [
		"ΌΠΧ ",
		"ΌΠΩ ",
		"ΌΠγ ",
		"≤░Δζ ",
		"≤░Δη ",
		"≤░Δθ ",
		"≤░Δι "
	],
	//"format": "{icon}",
	//"format-icons": ["ΌΠΧ","ΌΠΨ","ΌΠΩ","ΌΠα","ΌΠβ","ΌΠγ","ΌΠδ","ΌΠε","ΌΠζ","ΌΠη","ΌΠθ","ΌΠι","ΌΠκ","ΌΠλ","ΌΠμ"],
	"tooltip-format": "backlight {percent}%",
	"icon-size": 10,
	"on-click": "",
	"on-click-middle": "",
	"on-click-right": "",
	"on-update": "",
	"on-scroll-up": "brightnessctl s +5%",
	"on-scroll-down": "brightnessctl s 5%-",
	"smooth-scrolling-threshold": 1,
},
"mpris": {
	"interval": 10,
	"format": "{player_icon} {title}",
	"format-paused": "{status_icon} <i>{dynamic}</i>",
	"on-click-middle": "playerctl play-pause",
	"on-click": "playerctl previous",
	"on-click-right": "playerctl next",
	"scroll-step": 5.0,
	"on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-",
	"on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
	"smooth-scrolling-threshold": 1,
	"player-icons": {
		"chromium": "ΎΚρ",
		"default": "ΎΑζ",
		"firefox": "ΎΚσ",
		"kdeconnect": "Ύαθ",
		"mopidy": "ΎΑΒ",
		"mpv": "≤░Ρ╣",
		"spotify": "ΎΗ╝",
		"vlc": "≤░Χ╝",
		"strawberry": "ΎΑΒ",
	},
	"status-icons": {
		"paused": "≤░ΡΟ",
		"playing": "ΎΒΜ",
		"stopped": "ΎΒΞ",
	},
	// "ignored-players": ["firefox"]
	"max-length": 30,
}

}
